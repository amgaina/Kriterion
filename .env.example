# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# Database
POSTGRES_USER=kriterion
POSTGRES_PASSWORD=kriterion_dev_password
POSTGRES_DB=kriterion
DATABASE_URL=postgresql://kriterion:kriterion_dev_password@db:5432/kriterion

# Backend
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Redis (Docker Compose)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Kriterion

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Admin defaults
INITIAL_ADMIN_EMAIL=admin@kriterion.edu
INITIAL_ADMIN_PASSWORD=Admin@123456

# =============================================================================
# PRODUCTION: VERCEL (Frontend)
# Set these in Vercel Project Settings > Environment Variables
# =============================================================================
# NEXT_PUBLIC_API_URL=https://kriterion-api.onrender.com/api/v1
# NEXT_PUBLIC_APP_NAME=Kriterion

# =============================================================================
# PRODUCTION: RENDER (Backend)
# Set these in Render Dashboard > kriterion-api > Environment
# =============================================================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#   (from Render PostgreSQL, or Neon/Supabase)
#
# SECRET_KEY=<generate: openssl rand -hex 32>
# BACKEND_CORS_ORIGINS=["https://your-app.vercel.app","https://your-app.vercel.app/"]
#
# Redis Cloud - copy from Redis Cloud dashboard (Connections):
# CELERY_BROKER_URL=rediss://default:password@host:port
# CELERY_RESULT_BACKEND=rediss://default:password@host:port
#
# S3 (IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=kriterion-submissions
# USE_S3_STORAGE=true
#
# INITIAL_ADMIN_EMAIL=admin@yourdomain.edu
# INITIAL_ADMIN_PASSWORD=<strong-password>
# ENVIRONMENT=production
# DEBUG=false

# =============================================================================
# OPTIONAL (all environments)
# =============================================================================
# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SUBMIT=10/minute
RATE_LIMIT_API=100/minute

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.py,.java,.cpp,.c,.js,.ts,.txt,.md,.pdf

# Sandbox
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_CPU_LIMIT=1.0

# Email (optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@kriterion.edu
