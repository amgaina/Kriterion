# ===========================================
# KRITERION ENVIRONMENT VARIABLES
# ===========================================

# App Configuration
APP_NAME=Kriterion
VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Database
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://kriterion:kriterion_password@db:5432/kriterion

# Security
# Generate a strong secret key (use: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-replace-with-actual-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload Settings
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.py,.java,.cpp,.c,.js,.ts,.txt,.md,.pdf
UPLOAD_DIR=/tmp/kriterion/uploads
SUBMISSIONS_DIR=/tmp/kriterion/submissions
TEMP_DIR=/tmp/kriterion/temp

# ===========================================
# AWS S3 CONFIGURATION (REQUIRED)
# ===========================================
# AWS credentials for S3 file storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=kriterion-submissions

# Storage mode: true = use S3, false = use local storage
USE_S3_STORAGE=true

# ===========================================
# Optional: AWS S3 Bucket Setup Instructions
# ===========================================
# 1. Create an S3 bucket in AWS Console
# 2. Set bucket name in AWS_S3_BUCKET_NAME
# 3. Create an IAM user with S3 permissions
# 4. Attach this policy to the IAM user:
#    {
#      "Version": "2012-10-17",
#      "Statement": [
#        {
#          "Effect": "Allow",
#          "Action": [
#            "s3:PutObject",
#            "s3:GetObject",
#            "s3:DeleteObject",
#            "s3:ListBucket"
#          ],
#          "Resource": [
#            "arn:aws:s3:::kriterion-submissions/*",
#            "arn:aws:s3:::kriterion-submissions"
#          ]
#        }
#      ]
#    }
# 5. Get Access Key ID and Secret Access Key from IAM user
# 6. Set them in AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY

# Sandbox Configuration
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_CPU_LIMIT=1.0
SANDBOX_IMAGE=kriterion-sandbox:latest

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@kriterion.edu

# Logging
LOG_LEVEL=INFO

# Initial Admin Account
INITIAL_ADMIN_EMAIL=admin@kriterion.edu
INITIAL_ADMIN_PASSWORD=Admin@123456

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SUBMIT=10/minute
RATE_LIMIT_API=100/minute
